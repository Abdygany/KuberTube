    "lint": "eslint .",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "@learnspace/core": "workspace:*",
    "@learnspace/db": "workspace:*",
    "@trpc/server": "^11.0.0-rc.660",
    "better-auth": "^1.1.7",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.6.14",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@learnspace/config": "workspace:*",
    "@types/node": "^22.10.0",
    "eslint": "^9.17.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
