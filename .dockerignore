# Keep the Docker build context minimal so .env / .git / dev caches
# don't leak into image layers.

**/node_modules
**/.next
**/dist
**/.turbo
**/coverage

# Env / secrets — never bake into images.
**/.env
**/.env.*
!**/.env.example

# Version control + CI metadata
.git
.gitignore
.github
.husky

# Project metadata not needed at runtime
*.md
LICENSE
CONTRIBUTING.md

# Web app — apps/api Dockerfile doesn't ship the frontend
apps/web

# Local test/state
postgres-data
*.log
