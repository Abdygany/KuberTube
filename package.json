{
  "name": "kubertube",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20.10.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test -- --reporter=verbose",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,mjs,cjs}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,mjs,cjs}\"",
    "db:generate": "pnpm --filter @kubertube/db db:generate",
    "db:migrate": "pnpm --filter @kubertube/db db:migrate",
    "db:push": "pnpm --filter @kubertube/db db:push",
    "db:studio": "pnpm --filter @kubertube/db db:studio",
    "db:cleanup": "pnpm --filter @kubertube/db db:cleanup",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,mjs,cjs,js,jsx}": [
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "husky": "^9.1.6",
    "lint-staged": "^15.2.10",
    "prettier": "^3.3.3",
    "turbo": "^2.1.3",
    "typescript": "^5.6.3",
    "vitest": "^2.1.3"
  }
}
