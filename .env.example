# Database
DATABASE_URL=postgresql://learnspace:learnspace@localhost:5432/learnspace

# Auth (generate a strong secret: openssl rand -base64 32)
BETTER_AUTH_SECRET=replace-with-strong-secret
BETTER_AUTH_URL=http://localhost:3001

# Encryption for user API keys (generate 32 bytes hex: openssl rand -hex 32)
ENCRYPTION_KEY=replace-with-64-hex-chars

# URLs
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_APP_URL=http://localhost:3000
