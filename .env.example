# Корневой .env для локальной разработки. Скопируйте в .env и заполните.
# В прод никогда не коммитим — .env уже в .gitignore.

# --- Postgres (поднимается через docker-compose) ---
DATABASE_URL=postgres://learnspace:learnspace@localhost:5432/learnspace

# --- Шифрование API-ключей пользователя (AES-256-GCM мастер-ключ).
#     ≥32 символа. В проде — секрет, в локалке любая строка длиннее 32.
ENCRYPTION_KEY=local-dev-encryption-key-change-me-in-production-32chars

# --- Better Auth (сессии и подписи cookie). ≥32 символа.
AUTH_SECRET=local-dev-auth-secret-change-me-in-production-32chars-min

# --- Адрес API для Better Auth (он сам себе baseURL).
BETTER_AUTH_URL=http://localhost:3001

# --- Origin фронтенда для CORS и trustedOrigins.
WEB_ORIGIN=http://localhost:3000

# --- Фронтенд использует это для авторизации/tRPC. NEXT_PUBLIC_ префикс
#     означает «уйдёт в браузер». Только публичные значения.
NEXT_PUBLIC_API_URL=http://localhost:3001
